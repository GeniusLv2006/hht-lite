# 环境变量说明
# 复制为 .env 并填入实际值（.env 不入 Git）

# 管理员微信 OpenID（用于 /api/check-admin 和 /api/verify-admin）
ADMIN_OPENID=

# 初始化管理员账户（首次启动时生效，之后可删除）
INIT_ADMIN_USER=admin
INIT_ADMIN_PASSWORD=

# JWT 签名密钥（不设置则从 data/.jwt_secret 自动生成并持久化）
# JWT_SECRET=

# 日志保留天数（默认 30）
# LOG_RETENTION_DAYS=30

# 允许的前端域名（逗号分隔，默认 https://huihutong.xjtlu.uk）
# ALLOWED_ORIGINS=https://yourdomain.com
