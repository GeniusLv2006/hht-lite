# 环境变量说明
# 复制为 .env 并填入实际值（.env 不入 Git）

# Docker Compose 监听设置（默认仅允许本机反向代理访问）
HHT_BIND_HOST=127.0.0.1
HHT_HOST_PORT=3100
# 镜像标签；正式发布建议设置为精确版本，例如 v5.1.0
HHT_IMAGE_TAG=local

# 管理员微信 OpenID（用于管理员离线授权缓存）
ADMIN_OPENID=

# 初始化管理员账户（首次启动时生效，之后可删除）
INIT_ADMIN_USER=admin
INIT_ADMIN_PASSWORD=

# JWT 签名密钥（不设置则从 data/.jwt_secret 自动生成并持久化）
# JWT_SECRET=

# 日志保留天数（默认 30）
# LOG_RETENTION_DAYS=30

# 允许的 HTTPS 前端域名，多个域名使用逗号分隔
ALLOWED_ORIGINS=https://yourdomain.com
